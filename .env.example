# ===========================================
# SYNAPSIX ERP — Variables de Entorno
# Copiar este archivo a .env y completar valores reales
# NUNCA subir el archivo .env al repositorio
# ===========================================

# --- Django Core ---
DJANGO_SECRET_KEY=replace-with-a-very-long-random-secret-key-at-least-50-chars
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# --- Base de Datos PostgreSQL ---
DB_ENGINE=django.db.backends.postgresql
DB_NAME=synapsix_db
DB_USER=synapsix_user
DB_PASSWORD=synapsix_secure_password_2024
DB_HOST=db
DB_PORT=5432

# --- JWT Configuration ---
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# --- CORS (Frontend URL) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Frontend (React/Vite) ---
VITE_API_BASE_URL=http://localhost:8000

# --- Superuser inicial (solo para desarrollo) ---
DJANGO_SUPERUSER_EMAIL=admin@synapsix.com
DJANGO_SUPERUSER_PASSWORD=Admin1234!
DJANGO_SUPERUSER_FIRST_NAME=Super
DJANGO_SUPERUSER_LAST_NAME=Admin
